---
import { siteConfig } from "../data/docs";
---

<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div>
      <p class="site-footer__title">{siteConfig.name}</p>
      <p>
        Practical Cloudflare operations docs for DNS changes, token minting,
        Workers logs, R2 helpers, local profiles, and Wrangler account
        switching.
      </p>
    </div>
    <div>
      <p class="site-footer__title">Start here</p>
      <p>
        Begin with the quickstart, then use the docs reference for DNS,
        authentication, Workers, R2, Wrangler, and deployment workflows.
      </p>
    </div>
    <div>
      <p class="site-footer__title">Repository</p>
      <p>
        Source, releases, and CLI updates live in the GitHub repo at
        <a href={siteConfig.repoUrl} target="_blank" rel="noreferrer">
          {siteConfig.repoUrl.replace("https://", "")}
        </a>
        .
      </p>
    </div>
  </div>
</footer>
